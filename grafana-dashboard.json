{
  "dashboard": {
    "title": "Mock Server - Load Test Dashboard",
    "timezone": "browser",
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "panels": [
      {
        "id": 9,
        "title": "k6 동시 사용자 (VU)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "k6_vus",
            "legendFormat": "현재 VU"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2
            },
            "color": {
              "mode": "fixed",
              "fixedColor": "orange"
            }
          }
        }
      },
      {
        "id": 10,
        "title": "k6 클라이언트 측 응답시간 (초)",
        "description": "k6에서 측정한 응답시간 (대기열 대기 시간 포함)",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "k6_http_req_duration_avg",
            "legendFormat": "평균"
          },
          {
            "expr": "k6_http_req_duration_p50",
            "legendFormat": "P50 (중앙값)"
          },
          {
            "expr": "k6_http_req_duration_p95",
            "legendFormat": "P95"
          },
          {
            "expr": "k6_http_req_duration_p99",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "fillOpacity": 15
            }
          }
        }
      },
      {
        "id": 1,
        "title": "초당 처리 완료 (TPS)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{application=\"notification-mock-server\"}[30s])",
            "legendFormat": "{{method}} {{uri}} [{{status}}]"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 2,
        "title": "서버 측 평균 응답시간 (초)",
        "description": "서버에서 쓰레드가 요청을 처리한 시간만 측정 (대기열 대기 시간 미포함)",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum{application=\"notification-mock-server\"}[30s]) / rate(http_server_requests_seconds_count{application=\"notification-mock-server\"}[30s])",
            "legendFormat": "{{method}} {{uri}} [{{status}}]"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Tomcat 쓰레드 (활성 / 최대)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "tomcat_threads_busy_threads{application=\"notification-mock-server\"}",
            "legendFormat": "사용 중"
          },
          {
            "expr": "tomcat_threads_config_max_threads{application=\"notification-mock-server\"}",
            "legendFormat": "최대"
          },
          {
            "expr": "tomcat_threads_current_threads{application=\"notification-mock-server\"}",
            "legendFormat": "현재 생성됨"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 4,
        "title": "HTTP 에러율 (%)",
        "description": "서버 측: 처리한 요청 중 5xx 비율. k6 측: 연결 거부·타임아웃 포함 전체 실패율",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 16,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count{application=\"notification-mock-server\",status=~\"5..\"}[30s])) / sum(rate(http_server_requests_seconds_count{application=\"notification-mock-server\"}[30s])) * 100",
            "legendFormat": "서버 측 5xx 에러율"
          },
          {
            "expr": "k6_http_req_failed_rate * 100",
            "legendFormat": "k6 클라이언트 측 에러율"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "fillOpacity": 20
            },
            "color": {
              "mode": "fixed",
              "fixedColor": "red"
            }
          }
        }
      },
      {
        "id": 6,
        "title": "현재 동시 연결 수",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 24,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "tomcat_connections_current_connections{application=\"notification-mock-server\"}",
            "legendFormat": "현재 연결"
          },
          {
            "expr": "tomcat_connections_config_max_connections{application=\"notification-mock-server\"}",
            "legendFormat": "최대 연결"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "응답시간 P95 / P99 (초)",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 24,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"notification-mock-server\"}[30s])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"notification-mock-server\"}[30s])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 8,
        "title": "CPU 사용률 (%)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 32,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "process_cpu_usage{application=\"notification-mock-server\"} * 100",
            "legendFormat": "Mock 서버 프로세스"
          },
          {
            "expr": "system_cpu_usage{application=\"notification-mock-server\"} * 100",
            "legendFormat": "시스템 전체"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "fillOpacity": 15
            },
            "max": 100
          }
        }
      },
      {
        "id": 5,
        "title": "JVM Heap 메모리 사용량",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 32,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(jvm_memory_used_bytes{application=\"notification-mock-server\",area=\"heap\"})",
            "legendFormat": "사용 중"
          },
          {
            "expr": "sum(jvm_memory_max_bytes{application=\"notification-mock-server\",area=\"heap\"})",
            "legendFormat": "최대"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "fillOpacity": 10
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}